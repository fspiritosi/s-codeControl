// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_cron(schema: "public")]
}

// ============================================================
// ENUMS
// ============================================================

enum affiliate_status_enum {
  Dentro_de_convenio @map("Dentro de convenio")
  Fuera_de_convenio  @map("Fuera de convenio")
}

enum condition_enum {
  operativo
  no_operativo           @map("no operativo")
  en_reparacion          @map("en reparación")
  operativo_condicionado @map("operativo condicionado")
}

enum daily_report_status {
  pendiente
  ejecutado
  reprogramado
  cancelado
}

enum document_applies {
  Persona
  Equipos
  Empresa
}

enum document_type_enum {
  DNI
  LE
  LC
  PASAPORTE
}

enum gender_enum {
  Masculino
  Femenino
  No_Declarado @map("No Declarado")
}

enum hse_doc_status {
  pendiente
  aceptado
  rechazado
  pending
}

enum level_of_education_enum {
  Primario
  Secundario
  Terciario
  Universitario
  PosGrado
}

enum marital_status_enum {
  Casado
  Soltero
  Divorciado
  Viudo
  Separado
}

enum modulos {
  empresa
  empleados
  equipos
  documentacion @map("documentación")
  mantenimiento
  dashboard
  ayuda
  operaciones
  formularios
  proveedores
  almacenes
  compras
  tesoreria
}

enum nationality_enum {
  Argentina
  Extranjero
}

enum notification_categories {
  vencimiento
  noticia
  advertencia
  aprobado
  rechazado
}

enum reason_for_termination_enum {
  Despido_sin_causa @map("Despido sin causa")
  Renuncia
  Despido_con_causa @map("Despido con causa")
  Acuerdo_de_partes @map("Acuerdo de partes")
  Fin_de_contrato   @map("Fin de contrato")
  Fallecimiento
}

enum repair_state {
  Pendiente
  Esperando_repuestos @map("Esperando repuestos")
  En_reparacion       @map("En reparación")
  Finalizado
  Rechazado
  Cancelado
  Programado
}

enum roles_enum {
  Externo
  Auditor
}

enum state {
  presentado
  rechazado
  aprobado
  vencido
  pendiente
}

enum status_type {
  Avalado
  No_avalado               @map("No avalado")
  Incompleto
  Completo
  Completo_con_doc_vencida @map("Completo con doc vencida")
}

enum training_status {
  Borrador
  Archivado
  Publicado
}

enum expense_status {
  DRAFT
  CONFIRMED
  PARTIAL_PAID
  PAID
  CANCELLED
}

enum type_of_maintenance_ENUM {
  Correctivo
  Preventivo
}

// ============================================================
// MODELS
// ============================================================

model provinces {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  name       String

  cities    cities[]
  companies company[]   @relation("company_province")
  employees employees[] @relation("employees_province")

  @@unique([id], map: "provinces_id_key")
}

model cities {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz
  province_id BigInt
  name        String

  province  provinces   @relation(fields: [province_id], references: [id], onUpdate: Cascade)
  companies company[]   @relation("company_city")
  employees employees[] @relation("employees_city")

  @@index([province_id])
}

model countries {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  name       String

  employees employees[] @relation("employees_birthplace")
}

model roles {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @db.Timestamptz
  name        String   @unique
  is_active   Boolean? @default(true)
  intern      Boolean? @default(false)
  is_system   Boolean  @default(false)
  description String?
  company_id  String?  @db.Uuid

  company             company?              @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  profiles            profile[]
  share_company_users share_company_users[]
  role_permissions    role_permissions[]
  user_roles          user_roles[]

  @@index([company_id])
}

model permissions {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique
  module      String?
  action      String
  description String?
  is_system   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz

  role_permissions   role_permissions[]
  notification_types notification_types[] @relation("notification_types_required_permission")

  @@index([module])
}

model role_permissions {
  role_id       BigInt
  permission_id BigInt
  created_at    DateTime @default(now()) @db.Timestamptz

  role       roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id])
}

model user_roles {
  profile_id String   @db.Uuid
  company_id String   @db.Uuid
  role_id    BigInt
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String?  @db.Uuid

  profile            profile  @relation("user_roles_profile", fields: [profile_id], references: [id], onDelete: Cascade)
  company            company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  role               roles    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  created_by_profile profile? @relation("user_roles_created_by", fields: [created_by], references: [id], onDelete: SetNull)

  @@id([profile_id, company_id, role_id])
  @@index([company_id])
  @@index([role_id])
}

model notification_types {
  code                     String                   @id
  title_template           String
  description_template     String?
  category                 notification_categories?
  required_permission_code String?
  link_template            String?
  is_active                Boolean                  @default(true)
  is_system                Boolean                  @default(true)
  created_at               DateTime                 @default(now()) @db.Timestamptz

  required_permission permissions?    @relation("notification_types_required_permission", fields: [required_permission_code], references: [code], onDelete: SetNull)
  notifications       notifications[]
}

model notification_recipients {
  notification_id String    @db.Uuid
  profile_id      String    @db.Uuid
  read_at         DateTime? @db.Timestamptz
  dismissed_at    DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  notification notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  profile      profile       @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@id([notification_id, profile_id])
}

model profile {
  id            String    @id @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamptz
  credential_id String?   @unique(map: "profile_credentialId_key") @db.Uuid
  email         String?   @unique
  avatar        String?
  fullname      String?
  role          String?
  modulos       modulos[]
  password_hash String?   @db.Text

  role_rel                    roles?                    @relation(fields: [role], references: [name])
  owned_companies             company[]                 @relation("company_owner")
  share_company_users         share_company_users[]
  documents_employees         documents_employees[]     @relation("documents_employees_user")
  documents_equipment         documents_equipment[]     @relation("documents_equipment_user")
  documents_company           documents_company[]       @relation("documents_company_user")
  vehicles                    vehicles[]                @relation("vehicles_user")
  repair_solicitudes_mechanic repair_solicitudes[]      @relation("repair_mechanic")
  repair_solicitudes_user     repair_solicitudes[]      @relation("repair_user")
  repairlogs                  repairlogs[]              @relation("repairlogs_user")
  diagrams_logs               diagrams_logs[]           @relation("diagrams_logs_modified_by")
  user_roles                  user_roles[]              @relation("user_roles_profile")
  user_roles_created          user_roles[]              @relation("user_roles_created_by")
  notification_recipients     notification_recipients[]
}

model company {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_name     String   @db.VarChar(255)
  description      String
  website          String?  @db.VarChar(255)
  contact_email    String   @db.VarChar(255)
  contact_phone    String   @db.VarChar(20)
  address          String   @db.VarChar(255)
  city             BigInt
  country          String   @db.VarChar(100)
  industry         String
  company_logo     String?
  is_active        Boolean  @default(true)
  company_cuit     String   @unique(map: "company_compay_cuit_key")
  province_id      BigInt?
  owner_id         String?  @db.Uuid
  by_defect        Boolean? @default(false)
  company_group_id String?  @db.Uuid

  city_rel      cities          @relation("company_city", fields: [city], references: [id])
  province_rel  provinces?      @relation("company_province", fields: [province_id], references: [id])
  owner         profile?        @relation("company_owner", fields: [owner_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  company_group company_groups? @relation(fields: [company_group_id], references: [id], onUpdate: Cascade, onDelete: SetNull)

  employees              employees[]
  vehicles               vehicles[]
  companies_employees    companies_employees[]
  document_types         document_types[]
  notifications          notifications[]
  share_company_users    share_company_users[]
  brand_vehicles         brand_vehicles[]
  model_vehicles_company model_vehicles[]
  contacts               contacts[]
  customers              customers[]
  customer_services      customer_services[]
  custom_form            custom_form[]
  hired_modules          hired_modules[]
  diagram_type           diagram_type[]
  guild                  guild[]
  covenant               covenant[]
  types_of_repairs       types_of_repairs[]
  dailyreport            dailyreport[]
  service_items          service_items[]
  type                   type[]
  trainings              trainings[]
  hse_documents          hse_documents[]
  hse_doc_types          hse_doc_types[]
  hse_document_tags      hse_document_tags[]
  documentsCompanies     documents_company[]
  hierarchy              hierarchy[]
  work_diagram           work_diagram[]
  types_of_contracts     types_of_contracts[]

  // Almacenes y Compras
  products                    products[]
  suppliers                   suppliers[]
  supplier_payment_methods    supplier_payment_methods[]
  warehouses                  warehouses[]
  stock_movements             stock_movements[]
  purchase_orders             purchase_orders[]
  purchase_order_installments purchase_order_installments[]
  purchase_invoices           purchase_invoices[]
  receiving_notes             receiving_notes[]
  withdrawal_orders           withdrawal_orders[]

  // Tesorería
  cash_registers         cash_registers[]
  cash_register_sessions cash_register_sessions[]
  cash_movements         cash_movements[]
  bank_accounts          bank_accounts[]
  bank_movements         bank_movements[]
  checks                 checks[]
  payment_orders         payment_orders[]

  // Configuración
  pdf_settings       pdf_settings?
  pdf_email_settings pdf_email_settings[]

  // Roles y permisos
  roles      roles[]
  user_roles user_roles[]

  // Retenciones y percepciones
  tax_types                       tax_types[]
  retention_certificate_sequences retention_certificate_sequences[]

  // Gastos
  expense_categories expense_categories[]
  expenses           expenses[]
}

model pdf_settings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String   @unique @db.Uuid
  header_text         String?
  footer_text         String?
  signature_image_url String?
  signed_pdf_keys     String[] @default([])
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz

  company company @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
}

model pdf_email_settings {
  company_id String   @db.Uuid
  pdf_key    String
  from_email String
  from_name  String?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  company company @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([company_id, pdf_key])
  @@index([company_id])
}

model company_groups {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  created_at DateTime @default(now()) @db.Timestamptz

  companies company[]
}

model industry_type {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  name       String?  @unique(map: "industry_type_type_key")
  is_active  Boolean? @default(true)
}

model hierarchy {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  name       String
  is_active  Boolean? @default(true)
  company_id String?  @db.Uuid

  company   company?    @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  employees employees[]
}

model employees {
  id                     String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime                     @default(now()) @db.Timestamptz
  picture                String
  nationality            nationality_enum
  lastname               String
  firstname              String
  cuil                   String                       @unique(map: "companies_employees_cuil_key")
  document_type          document_type_enum
  document_number        String                       @unique(map: "companies_employees_document_number_key")
  birthplace             String                       @db.Uuid
  gender                 gender_enum?
  marital_status         marital_status_enum?
  level_of_education     level_of_education_enum?
  street                 String
  street_number          String
  province               BigInt
  postal_code            String?
  phone                  String
  email                  String?
  file                   String
  normal_hours           String?
  date_of_admission      DateTime                     @db.Date
  affiliate_status       affiliate_status_enum?
  company_position       String?
  city                   BigInt
  hierarchical_position  String?                      @db.Uuid
  workflow_diagram       String?                      @db.Uuid
  type_of_contract       String
  allocated_to           String[]                     @db.Uuid
  company_id             String?                      @db.Uuid
  is_active              Boolean?                     @default(true)
  reason_for_termination reason_for_termination_enum?
  termination_date       DateTime?                    @db.Date
  status                 status_type?                 @default(No_avalado)
  born_date              String?
  category_id            String?                      @db.Uuid
  covenants_id           String?                      @db.Uuid
  guild_id               String?                      @db.Uuid

  birthplace_rel       countries     @relation("employees_birthplace", fields: [birthplace], references: [id], onUpdate: Cascade, onDelete: Cascade)
  city_rel             cities        @relation("employees_city", fields: [city], references: [id])
  company              company?      @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  hierarchy_rel        hierarchy?    @relation(fields: [hierarchical_position], references: [id])
  province_rel         provinces     @relation("employees_province", fields: [province], references: [id])
  workflow_diagram_rel work_diagram? @relation(fields: [workflow_diagram], references: [id])
  category_rel         category?     @relation(fields: [category_id], references: [id])
  covenants_rel        covenant?     @relation(fields: [covenants_id], references: [id])
  guild_rel            guild?        @relation(fields: [guild_id], references: [id])

  companies_employees              companies_employees[]
  documents_employees              documents_employees[]
  contractor_employee              contractor_employee[]
  assing_customer                  assing_customer[]
  employees_diagram                employees_diagram[]
  category_employee                category_employee[]
  dailyreportemployeerelations     dailyreportemployeerelations[]
  repair_solicitudes               repair_solicitudes[]
  withdrawal_orders                withdrawal_orders[]
  repairlogs                       repairlogs[]
  diagrams_logs                    diagrams_logs[]
  employee_material_progress       employee_material_progress[]
  training_assignments             training_assignments[]
  training_attempts                training_attempts[]
  training_material_readings       training_material_readings[]
  hse_document_assignments         hse_document_assignments[]
  hse_document_assignment_versions hse_document_assignment_versions[]
}

model companies_employees {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id String  @db.Uuid
  company_id  String? @db.Uuid

  employee employees @relation(fields: [employee_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  company  company?  @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@index([company_id])
  @@index([employee_id])
}

model brand_vehicles {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  name       String?  @unique
  company_id String?  @db.Uuid
  is_active  Boolean? @default(true)

  company        company?         @relation(fields: [company_id], references: [id])
  model_vehicles model_vehicles[]
  vehicles       vehicles[]       @relation("vehicles_brand")
}

model model_vehicles {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  name       String?
  brand      BigInt?
  is_active  Boolean? @default(true)
  company_id String?  @db.Uuid

  brand_rel brand_vehicles? @relation(fields: [brand], references: [id])
  company   company?        @relation(fields: [company_id], references: [id])
  vehicles  vehicles[]      @relation("vehicles_model")
}

model types_of_vehicles {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  name       String?
  is_active  Boolean? @default(true)

  vehicles vehicles[]
}

model type {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  name       String
  company_id String?  @db.Uuid
  is_active  Boolean? @default(true)

  company  company?   @relation(fields: [company_id], references: [id])
  vehicles vehicles[]
}

model vehicles {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime        @default(now()) @db.Timestamptz
  picture                String
  type_of_vehicle        BigInt
  domain                 String?         @unique
  chassis                String?
  engine                 String
  serie                  String?
  intern_number          String
  year                   String
  brand                  BigInt
  model                  BigInt
  is_active              Boolean?        @default(true)
  termination_date       DateTime?       @db.Date
  reason_for_termination String?
  user_id                String?         @db.Uuid
  company_id             String?         @db.Uuid
  type                   String          @db.Uuid
  status                 status_type?    @default(No_avalado)
  allocated_to           String[]        @db.Uuid
  kilometer              String?
  condition              condition_enum?

  type_of_vehicle_rel types_of_vehicles @relation(fields: [type_of_vehicle], references: [id])
  brand_rel           brand_vehicles    @relation("vehicles_brand", fields: [brand], references: [id])
  model_rel           model_vehicles    @relation("vehicles_model", fields: [model], references: [id])
  type_rel            type              @relation(fields: [type], references: [id])
  user                profile?          @relation("vehicles_user", fields: [user_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  company             company?          @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  documents_equipment           documents_equipment[]
  contractor_equipment          contractor_equipment[]
  assing_customer               assing_customer[]
  dailyreportequipmentrelations dailyreportequipmentrelations[]
  repair_solicitudes            repair_solicitudes[]
  withdrawal_orders             withdrawal_orders[]
}

model work_diagram {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  name       String
  is_active  Boolean? @default(true)
  company_id String?  @db.Uuid

  company   company?    @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  employees employees[]

  @@map("work-diagram")
}

model types_of_contracts {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  name       String
  is_active  Boolean  @default(true)
  company_id String?  @db.Uuid

  company company? @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@index([company_id])
}

model document_types {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at    DateTime         @default(now()) @db.Timestamptz
  name          String           @unique
  applies       document_applies
  multiresource Boolean
  mandatory     Boolean
  explired      Boolean
  special       Boolean
  is_active     Boolean          @default(true)
  description   String?
  company_id    String?          @db.Uuid
  private       Boolean?
  is_it_montlhy Boolean?
  down_document Boolean?
  conditions    Json[]

  company             company?              @relation(fields: [company_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  documents_employees documents_employees[]
  documents_equipment documents_equipment[]
  documents_company   documents_company[]
}

model documents_employees {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  id_document_types String?  @db.Uuid
  validity          String?
  state             state    @default(pendiente)
  is_active         Boolean? @default(true)
  user_id           String?  @db.Uuid
  applies           String?  @db.Uuid
  deny_reason       String?
  document_path     String?  @unique(map: "documents_employees_docoment_path_key")
  period            String?

  document_type document_types? @relation(fields: [id_document_types], references: [id], onUpdate: Cascade, onDelete: Cascade)
  user          profile?        @relation("documents_employees_user", fields: [user_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
  employee      employees?      @relation(fields: [applies], references: [id], onUpdate: Cascade, onDelete: Cascade)

  logs documents_employees_logs[]
}

model documents_employees_logs {
  id                     Int      @id @default(autoincrement())
  documents_employees_id String   @db.Uuid
  modified_by            String   @db.Uuid
  updated_at             DateTime @default(now()) @db.Timestamptz

  documents_employees documents_employees @relation(fields: [documents_employees_id], references: [id], onUpdate: Cascade, onDelete: Cascade)
}

model documents_equipment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  id_document_types String?  @db.Uuid
  applies           String?  @db.Uuid
  validity          String?
  state             state?   @default(pendiente)
  is_active         Boolean? @default(true)
  user_id           String?  @db.Uuid
  deny_reason       String?
  document_path     String?  @unique
  period            String?

  document_type document_types? @relation(fields: [id_document_types], references: [id], onUpdate: Cascade, onDelete: Cascade)
  vehicle       vehicles?       @relation(fields: [applies], references: [id], onUpdate: Cascade, onDelete: Cascade)
  user          profile?        @relation("documents_equipment_user", fields: [user_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  logs documents_equipment_logs[]
}

model documents_equipment_logs {
  id                     Int      @id @default(autoincrement())
  documents_equipment_id String   @db.Uuid
  modified_by            String   @db.Uuid
  updated_at             DateTime @default(now()) @db.Timestamptz

