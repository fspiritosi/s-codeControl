// ============================================================
// MODELS — Productos
// ============================================================

model products {
  id                    String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id            String                     @db.Uuid
  code                  String
  name                  String
  description           String?
  type                  product_type               @default(PRODUCT)
  unit_of_measure       String                     @default("UN")
  cost_price            Decimal                    @default(0) @db.Decimal(12, 2)
  sale_price            Decimal                    @default(0) @db.Decimal(12, 2)
  vat_rate              Decimal                    @default(21) @db.Decimal(5, 2)
  purchase_sale_type    product_purchase_sale_type @default(PURCHASE_SALE)
  profit_margin_percent Decimal?                   @db.Decimal(7, 2)
  track_stock           Boolean                    @default(true)
  min_stock             Decimal?                   @default(0) @db.Decimal(12, 3)
  max_stock             Decimal?                   @db.Decimal(12, 3)
  barcode               String?                    @unique
  brand                 String?
  status                product_status             @default(ACTIVE)
  created_at            DateTime                   @default(now()) @db.Timestamptz
  updated_at            DateTime                   @default(now()) @updatedAt @db.Timestamptz

  company                company                  @relation(fields: [company_id], references: [id])
  warehouse_stocks       warehouse_stocks[]
  stock_movements        stock_movements[]
  purchase_order_lines   purchase_order_lines[]
  purchase_invoice_lines purchase_invoice_lines[]
  receiving_note_lines   receiving_note_lines[]
  withdrawal_order_lines withdrawal_order_lines[]

  @@unique([company_id, code])
}

// ============================================================
// MODELS — Proveedores
// ============================================================

model suppliers {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id        String                 @db.Uuid
  code              String
  business_name     String
  trade_name        String?
  tax_id            String
  tax_condition     supplier_tax_condition
  email             String?
  phone             String?
  website           String?
  address           String?
  city              String?
  province          String?
  zip_code          String?
  country           String                 @default("Argentina")
  payment_term_days Int                    @default(0)
  credit_limit      Decimal?               @db.Decimal(12, 2)
  contact_name      String?
  contact_phone     String?
  contact_email     String?
  status            supplier_status        @default(ACTIVE)
  notes             String?
  created_at        DateTime               @default(now()) @db.Timestamptz
  updated_at        DateTime               @default(now()) @updatedAt @db.Timestamptz

  company           company                    @relation(fields: [company_id], references: [id])
  purchase_orders   purchase_orders[]
  purchase_invoices purchase_invoices[]
  receiving_notes   receiving_notes[]
  payment_orders    payment_orders[]
  checks            checks[]
  payment_methods   supplier_payment_methods[]
  expenses          expenses[]

  @@unique([company_id, code])
  @@unique([company_id, tax_id])
}

model supplier_payment_methods {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplier_id           String                 @db.Uuid
  company_id            String                 @db.Uuid
  type                  payment_method
  bank_name             String?
  account_holder        String?
  account_holder_tax_id String?
  account_type          supplier_account_type?
  cbu                   String?                @db.VarChar(22)
  alias                 String?
  currency              String?
  is_default            Boolean                @default(false)
  status                supplier_status        @default(ACTIVE)
  created_at            DateTime               @default(now()) @db.Timestamptz
  updated_at            DateTime               @default(now()) @updatedAt @db.Timestamptz
  created_by            String?                @db.Uuid
  updated_by            String?                @db.Uuid

  supplier               suppliers                @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  company                company                  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  payment_order_payments payment_order_payments[]

  @@index([supplier_id])
  @@index([company_id, supplier_id])
}

// ============================================================
// MODELS — Almacenes y Stock
// ============================================================

model warehouses {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String         @db.Uuid
  code       String
  name       String
  type       warehouse_type @default(MAIN)
  address    String?
  city       String?
  province   String?
  is_active  Boolean        @default(true)
  created_at DateTime       @default(now()) @db.Timestamptz
  updated_at DateTime       @default(now()) @updatedAt @db.Timestamptz

  company           company             @relation(fields: [company_id], references: [id])
  stocks            warehouse_stocks[]
  movements         stock_movements[]
  receiving_notes   receiving_notes[]
  withdrawal_orders withdrawal_orders[]

  @@unique([company_id, code])
}

model warehouse_stocks {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouse_id  String   @db.Uuid
  product_id    String   @db.Uuid
  quantity      Decimal  @default(0) @db.Decimal(12, 3)
  reserved_qty  Decimal  @default(0) @db.Decimal(12, 3)
  available_qty Decimal  @default(0) @db.Decimal(12, 3)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  warehouse warehouses @relation(fields: [warehouse_id], references: [id])
  product   products   @relation(fields: [product_id], references: [id])

  @@unique([warehouse_id, product_id])
}

model stock_movements {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id     String              @db.Uuid
  warehouse_id   String              @db.Uuid
  product_id     String              @db.Uuid
  type           stock_movement_type
  quantity       Decimal             @db.Decimal(12, 3)
  reference_type String?
  reference_id   String?             @db.Uuid
  notes          String?
  date           DateTime            @default(now()) @db.Timestamptz
  created_by     String?
  created_at     DateTime            @default(now()) @db.Timestamptz

  company   company    @relation(fields: [company_id], references: [id])
  warehouse warehouses @relation(fields: [warehouse_id], references: [id])
  product   products   @relation(fields: [product_id], references: [id])
}

// ============================================================
// MODELS — Órdenes de Compra
// ============================================================

model purchase_orders {
  id                     String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id             String                          @db.Uuid
  supplier_id            String                          @db.Uuid
  number                 Int
  full_number            String
  issue_date             DateTime                        @db.Date
  expected_delivery_date DateTime?                       @db.Date
  payment_conditions     String?
  delivery_address       String?
  delivery_notes         String?
  subtotal               Decimal                         @default(0) @db.Decimal(12, 2)
  vat_amount             Decimal                         @default(0) @db.Decimal(12, 2)
  total                  Decimal                         @default(0) @db.Decimal(12, 2)
  notes                  String?
  status                 purchase_order_status           @default(DRAFT)
  invoicing_status       purchase_order_invoicing_status @default(NOT_INVOICED)
  approved_by            String?
  approved_at            DateTime?                       @db.Timestamptz
  created_by             String?
  created_at             DateTime                        @default(now()) @db.Timestamptz
  updated_at             DateTime                        @default(now()) @updatedAt @db.Timestamptz

  company           company                       @relation(fields: [company_id], references: [id])
  supplier          suppliers                     @relation(fields: [supplier_id], references: [id])
  lines             purchase_order_lines[]
  installments      purchase_order_installments[]
  receiving_notes   receiving_notes[]
  purchase_invoices purchase_invoices[]

  @@unique([company_id, number])
  @@index([company_id, status])
}

model purchase_order_lines {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     String  @db.Uuid
  product_id   String? @db.Uuid
  description  String
  quantity     Decimal @db.Decimal(12, 3)
  unit_cost    Decimal @db.Decimal(12, 3)
  vat_rate     Decimal @db.Decimal(5, 2)
  vat_amount   Decimal @db.Decimal(12, 3)
  subtotal     Decimal @db.Decimal(12, 3)
  total        Decimal @db.Decimal(12, 3)
  received_qty Decimal @default(0) @db.Decimal(12, 3)
  invoiced_qty Decimal @default(0) @db.Decimal(12, 3)

  order                  purchase_orders          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product                products?                @relation(fields: [product_id], references: [id])
  receiving_note_lines   receiving_note_lines[]
  purchase_invoice_lines purchase_invoice_lines[]
}

model purchase_order_installments {
  id                  String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String                            @db.Uuid
  order_id            String                            @db.Uuid
  number              Int
  due_date            DateTime                          @db.Date
  amount              Decimal                           @db.Decimal(12, 2)
  status              purchase_order_installment_status @default(PENDING)
  purchase_invoice_id String?                           @db.Uuid
  notes               String?
  created_at          DateTime                          @default(now()) @db.Timestamptz
  updated_at          DateTime                          @default(now()) @updatedAt @db.Timestamptz

  company          company            @relation(fields: [company_id], references: [id])
  order            purchase_orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  purchase_invoice purchase_invoices? @relation(fields: [purchase_invoice_id], references: [id])

  @@unique([order_id, number])
  @@index([company_id, order_id])
}

// ============================================================
// MODELS — Facturas de Compra
// ============================================================

model purchase_invoices {
  id                  String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String                            @db.Uuid
  supplier_id         String                            @db.Uuid
  voucher_type        voucher_type
  point_of_sale       String
  number              String
  full_number         String
  issue_date          DateTime                          @db.Timestamptz
  due_date            DateTime?                         @db.Timestamptz
  cae                 String?
  subtotal            Decimal                           @default(0) @db.Decimal(12, 2)
  vat_amount          Decimal                           @default(0) @db.Decimal(12, 2)
  other_taxes         Decimal                           @default(0) @db.Decimal(12, 2)
  total               Decimal                           @default(0) @db.Decimal(12, 2)
  notes               String?
  status              purchase_invoice_status           @default(DRAFT)
  receiving_status    purchase_invoice_receiving_status @default(NOT_RECEIVED)
  document_url        String?
  document_key        String?
  original_invoice_id String?                           @db.Uuid
  purchase_order_id   String?                           @db.Uuid
  global_discount_type   discount_type?
  global_discount_value  Decimal?                         @db.Decimal(12, 2)
  discount_amount        Decimal                          @default(0) @db.Decimal(12, 2)
  created_by          String?
  created_at          DateTime                          @default(now()) @db.Timestamptz
  updated_at          DateTime                          @default(now()) @updatedAt @db.Timestamptz

  company             company                        @relation(fields: [company_id], references: [id])
  supplier            suppliers                      @relation(fields: [supplier_id], references: [id])
  purchase_order      purchase_orders?               @relation(fields: [purchase_order_id], references: [id])
  original_invoice    purchase_invoices?             @relation("purchase_invoice_credit_notes", fields: [original_invoice_id], references: [id])
  credit_notes        purchase_invoices[]            @relation("purchase_invoice_credit_notes")
  lines               purchase_invoice_lines[]
  installments        purchase_order_installments[]
  receiving_notes     receiving_notes[]
  payment_order_items payment_order_items[]
  cash_movements      cash_movements[]
  perceptions         purchase_invoice_perceptions[]

  @@unique([company_id, supplier_id, full_number])
  @@index([purchase_order_id])
}

model purchase_invoice_lines {
  id                     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id             String  @db.Uuid
  product_id             String? @db.Uuid
  description            String
  quantity               Decimal @db.Decimal(12, 3)
  unit_cost              Decimal @db.Decimal(12, 3)
  vat_rate               Decimal @db.Decimal(5, 2)
  vat_amount             Decimal @db.Decimal(12, 3)
  subtotal               Decimal @db.Decimal(12, 3)
  total                  Decimal @db.Decimal(12, 3)
  purchase_order_line_id String?        @db.Uuid
  received_qty           Decimal        @default(0) @db.Decimal(12, 3)
  discount_type          discount_type?
  discount_value         Decimal?       @db.Decimal(12, 3)
  discount_amount        Decimal        @default(0) @db.Decimal(12, 3)

  invoice              purchase_invoices      @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product              products?              @relation(fields: [product_id], references: [id])
  purchase_order_line  purchase_order_lines?  @relation(fields: [purchase_order_line_id], references: [id])
  receiving_note_lines receiving_note_lines[]
}

// ============================================================
// MODELS — Remitos de Recepción
// ============================================================

model receiving_notes {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String                @db.Uuid
  supplier_id         String                @db.Uuid
  warehouse_id        String                @db.Uuid
  number              Int
  full_number         String
  purchase_order_id   String?               @db.Uuid
  purchase_invoice_id String?               @db.Uuid
  reception_date      DateTime              @db.Date
  notes               String?
  status              receiving_note_status @default(DRAFT)
  created_by          String?
  created_at          DateTime              @default(now()) @db.Timestamptz
  updated_at          DateTime              @default(now()) @updatedAt @db.Timestamptz

  company          company                @relation(fields: [company_id], references: [id])
  supplier         suppliers              @relation(fields: [supplier_id], references: [id])
  warehouse        warehouses             @relation(fields: [warehouse_id], references: [id])
  purchase_order   purchase_orders?       @relation(fields: [purchase_order_id], references: [id])
  purchase_invoice purchase_invoices?     @relation(fields: [purchase_invoice_id], references: [id])
  lines            receiving_note_lines[]

  @@unique([company_id, number])
  @@index([company_id, status])
  @@index([purchase_order_id])
  @@index([purchase_invoice_id])
}

model receiving_note_lines {
  id                       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiving_note_id        String  @db.Uuid
  product_id               String  @db.Uuid
  description              String
  quantity                 Decimal @db.Decimal(12, 3)
  purchase_order_line_id   String? @db.Uuid
  purchase_invoice_line_id String? @db.Uuid
  notes                    String?

  receiving_note        receiving_notes         @relation(fields: [receiving_note_id], references: [id], onDelete: Cascade)
  product               products                @relation(fields: [product_id], references: [id])
  purchase_order_line   purchase_order_lines?   @relation(fields: [purchase_order_line_id], references: [id])
  purchase_invoice_line purchase_invoice_lines? @relation(fields: [purchase_invoice_line_id], references: [id])

  @@index([purchase_invoice_line_id])
}

// ============================================================
// MODELS — Órdenes de Retiro de Materiales
// ============================================================

model withdrawal_orders {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id   String                  @db.Uuid
  warehouse_id String                  @db.Uuid
  number       Int
  full_number  String
  request_date DateTime                @db.Date
  notes        String?
  status       withdrawal_order_status @default(DRAFT)
  approved_by  String?
  approved_at  DateTime?               @db.Timestamptz
  completed_at DateTime?               @db.Timestamptz
  // Opcional: quién retira y para qué equipo
  employee_id  String?                 @db.Uuid
  vehicle_id   String?                 @db.Uuid
  created_by   String?
  created_at   DateTime                @default(now()) @db.Timestamptz
  updated_at   DateTime                @default(now()) @updatedAt @db.Timestamptz

  company   company                  @relation(fields: [company_id], references: [id])
  warehouse warehouses               @relation(fields: [warehouse_id], references: [id])
  employee  employees?               @relation(fields: [employee_id], references: [id])
  vehicle   vehicles?                @relation(fields: [vehicle_id], references: [id])
  lines     withdrawal_order_lines[]

  @@unique([company_id, number])
  @@index([company_id, status])
}

model withdrawal_order_lines {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id    String  @db.Uuid
  product_id  String  @db.Uuid
  description String
  quantity    Decimal @db.Decimal(12, 3)
  notes       String?

  order   withdrawal_orders @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product products          @relation(fields: [product_id], references: [id])
}

// ============================================================
// ENUMS — Tesorería
// ============================================================

enum cash_register_status {
  ACTIVE
  INACTIVE
}

enum session_status {
  OPEN
  CLOSED
}

enum cash_movement_type {
  OPENING
  CLOSING
  INCOME
  EXPENSE
  ADJUSTMENT
}

enum bank_account_type {
  CHECKING
  SAVINGS
  CREDIT
  CASH
  VIRTUAL_WALLET
}

enum bank_account_status {
  ACTIVE
  INACTIVE
  CLOSED
}

enum bank_movement_type {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  CHECK
  DEBIT
  FEE
  INTEREST
}

enum payment_method {
  CASH
  CHECK
  TRANSFER
  DEBIT_CARD
  CREDIT_CARD
  ACCOUNT
}

enum payment_order_status {
  DRAFT
  CONFIRMED
  PAID
  CANCELLED
}

enum check_type {
  OWN
  THIRD_PARTY
}

enum check_status {
  PORTFOLIO
  DEPOSITED
  CLEARED
  REJECTED
  ENDORSED
  DELIVERED
  CASHED
  VOIDED
}

// ============================================================
// MODELS — Tesorería (Cajas Físicas)
// ============================================================

model cash_registers {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String               @db.Uuid
  code       String
  name       String
  location   String?
  status     cash_register_status @default(ACTIVE)
  is_default Boolean              @default(false)
  created_by String?
  created_at DateTime             @default(now()) @db.Timestamptz
  updated_at DateTime             @default(now()) @updatedAt @db.Timestamptz

  company                company                  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  sessions               cash_register_sessions[]
  movements              cash_movements[]
  payment_order_payments payment_order_payments[]

  @@unique([company_id, code])
  @@index([company_id, status])
}

model cash_register_sessions {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cash_register_id String         @db.Uuid
  company_id       String         @db.Uuid
  session_number   Int
  status           session_status @default(OPEN)
  opening_balance  Decimal        @default(0) @db.Decimal(15, 2)
  expected_balance Decimal        @default(0) @db.Decimal(15, 2)
  actual_balance   Decimal?       @db.Decimal(15, 2)
  difference       Decimal?       @db.Decimal(15, 2)
  opening_notes    String?
  closing_notes    String?
  opened_by        String
  closed_by        String?
  opened_at        DateTime       @default(now()) @db.Timestamptz
  closed_at        DateTime?      @db.Timestamptz
  created_at       DateTime       @default(now()) @db.Timestamptz
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz

  cash_register cash_registers   @relation(fields: [cash_register_id], references: [id], onDelete: Cascade)
  company       company          @relation(fields: [company_id], references: [id], onDelete: Cascade)
  movements     cash_movements[]

  @@unique([cash_register_id, session_number])
  @@index([company_id, status])
  @@index([cash_register_id, status])
}

model cash_movements {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id          String             @db.Uuid
  cash_register_id    String             @db.Uuid
  company_id          String             @db.Uuid
  type                cash_movement_type
  amount              Decimal            @db.Decimal(15, 2)
  date                DateTime           @default(now()) @db.Timestamptz
  description         String
  reference           String?
  purchase_invoice_id String?            @db.Uuid
  payment_order_id    String?            @db.Uuid
  created_by          String
  created_at          DateTime           @default(now()) @db.Timestamptz
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamptz

  session          cash_register_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  cash_register    cash_registers         @relation(fields: [cash_register_id], references: [id], onDelete: Cascade)
  company          company                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  purchase_invoice purchase_invoices?     @relation(fields: [purchase_invoice_id], references: [id])
  payment_order    payment_orders?        @relation(fields: [payment_order_id], references: [id], onDelete: SetNull)

  @@index([company_id, date])
  @@index([session_id, type])
  @@index([cash_register_id, date])
  @@index([payment_order_id])
}

// ============================================================
// MODELS — Tesorería (Bancos)
// ============================================================

model bank_accounts {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id     String              @db.Uuid
  bank_name      String
  account_number String
  account_type   bank_account_type
  cbu            String?
  alias          String?
  currency       String              @default("ARS")
  balance        Decimal             @default(0) @db.Decimal(15, 2)
  status         bank_account_status @default(ACTIVE)
  created_by     String?
  created_at     DateTime            @default(now()) @db.Timestamptz
  updated_at     DateTime            @default(now()) @updatedAt @db.Timestamptz

  company                company                  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  movements              bank_movements[]
  payment_order_payments payment_order_payments[]
  checks                 checks[]

  @@unique([company_id, account_number])
  @@index([company_id, status])
}

model bank_movements {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bank_account_id  String             @db.Uuid
  company_id       String             @db.Uuid
  type             bank_movement_type
  amount           Decimal            @db.Decimal(15, 2)
  date             DateTime           @db.Timestamptz
  description      String
  reference        String?
  statement_number String?
  reference_type   String?
  reference_id     String?            @db.Uuid
  payment_order_id String?            @db.Uuid
  reconciled       Boolean            @default(false)
  reconciled_at    DateTime?          @db.Timestamptz
  reconciled_by    String?
  created_by       String
  created_at       DateTime           @default(now()) @db.Timestamptz
  updated_at       DateTime           @default(now()) @updatedAt @db.Timestamptz

  bank_account  bank_accounts   @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  company       company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  payment_order payment_orders? @relation(fields: [payment_order_id], references: [id])
  check         checks?

  @@index([company_id, date])
  @@index([bank_account_id, date])
  @@index([reconciled])
}

// ============================================================
// MODELS — Tesorería (Órdenes de Pago)
// ============================================================

model payment_orders {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id             String               @db.Uuid
  supplier_id            String?              @db.Uuid
  number                 Int
  full_number            String
  date                   DateTime             @db.Timestamptz
  total_amount           Decimal              @db.Decimal(15, 2)
  retentions_total       Decimal              @default(0) @db.Decimal(15, 2)
  net_to_pay             Decimal?             @db.Decimal(15, 2)
  notes                  String?
  status                 payment_order_status @default(DRAFT)
  document_url           String?
  document_key           String?
  created_by             String
  confirmed_by           String?
  confirmed_at           DateTime?            @db.Timestamptz
  paid_by                String?
  paid_at                DateTime?            @db.Timestamptz
  scheduled_payment_date DateTime?            @db.Date
  created_at             DateTime             @default(now()) @db.Timestamptz
  updated_at             DateTime             @default(now()) @updatedAt @db.Timestamptz

  company        company                    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  supplier       suppliers?                 @relation(fields: [supplier_id], references: [id])
  items          payment_order_items[]
  payments       payment_order_payments[]
  bank_movements bank_movements[]
  cash_movements cash_movements[]
  retentions     payment_order_retentions[]

  @@unique([company_id, number])
  @@index([company_id, status])
  @@index([supplier_id, status])
}

// ============================================================
// RETENCIONES Y PERCEPCIONES (Fase 1)
// ============================================================

enum tax_kind {
  RETENTION
  PERCEPTION
}

enum tax_scope {
  NATIONAL
  PROVINCIAL
  MUNICIPAL
}

enum tax_calculation_base {
  NET
  TOTAL
  VAT
}

model tax_types {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id         String               @db.Uuid
  code               String
  name               String
  kind               tax_kind
  scope              tax_scope            @default(NATIONAL)
  jurisdiction       String?
  calculation_base   tax_calculation_base @default(NET)
  default_rate       Decimal              @default(0) @db.Decimal(8, 4)
  min_taxable_amount Decimal?             @db.Decimal(15, 2)
  is_active          Boolean              @default(true)
  notes              String?
  created_at         DateTime             @default(now()) @db.Timestamptz
  updated_at         DateTime             @default(now()) @updatedAt @db.Timestamptz

  company             company                          @relation(fields: [company_id], references: [id], onDelete: Cascade)
  invoice_perceptions purchase_invoice_perceptions[]
  order_retentions    payment_order_retentions[]
  certificate_seq     retention_certificate_sequences[]

  @@unique([company_id, code], map: "tax_types_company_code_unique")
}

model purchase_invoice_perceptions {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id  String   @db.Uuid
  tax_type_id String   @db.Uuid
  base_amount Decimal  @db.Decimal(15, 3)
  rate        Decimal  @db.Decimal(8, 4)
  amount      Decimal  @db.Decimal(15, 3)
  notes       String?
  created_at  DateTime @default(now()) @db.Timestamptz

  invoice  purchase_invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  tax_type tax_types         @relation(fields: [tax_type_id], references: [id])

  @@index([invoice_id])
  @@index([tax_type_id])
}

model payment_order_retentions {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_order_id   String   @db.Uuid
  tax_type_id        String   @db.Uuid
  base_amount        Decimal  @db.Decimal(15, 2)
  rate               Decimal  @db.Decimal(8, 4)
  amount             Decimal  @db.Decimal(15, 2)
  certificate_number String?
  certificate_url    String?
  notes              String?
  created_at         DateTime @default(now()) @db.Timestamptz

  payment_order payment_orders @relation(fields: [payment_order_id], references: [id], onDelete: Cascade)
  tax_type      tax_types      @relation(fields: [tax_type_id], references: [id])

  @@index([payment_order_id])
  @@index([tax_type_id])
}

model retention_certificate_sequences {
  company_id  String   @db.Uuid
  tax_type_id String   @db.Uuid
  last_number Int      @default(0)
  updated_at  DateTime @default(now()) @db.Timestamptz

  company  company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  tax_type tax_types @relation(fields: [tax_type_id], references: [id], onDelete: Cascade)

  @@id([company_id, tax_type_id])
}

model payment_order_items {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_order_id String  @db.Uuid
  invoice_id       String? @db.Uuid
  expense_id       String? @db.Uuid
  amount           Decimal @db.Decimal(15, 2)

  payment_order payment_orders     @relation(fields: [payment_order_id], references: [id], onDelete: Cascade)
  invoice       purchase_invoices? @relation(fields: [invoice_id], references: [id])
  expense       expenses?          @relation(fields: [expense_id], references: [id])

  @@index([payment_order_id])
  @@index([invoice_id])
  @@index([expense_id])
}

model payment_order_payments {
  id                         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_order_id           String         @db.Uuid
  payment_method             payment_method
  amount                     Decimal        @db.Decimal(15, 2)
  cash_register_id           String?        @db.Uuid
  bank_account_id            String?        @db.Uuid
  supplier_payment_method_id String?        @db.Uuid
  check_number               String?
  card_last4                 String?
  reference                  String?

  payment_order           payment_orders            @relation(fields: [payment_order_id], references: [id], onDelete: Cascade)
  cash_register           cash_registers?           @relation(fields: [cash_register_id], references: [id])
  bank_account            bank_accounts?            @relation(fields: [bank_account_id], references: [id])
  supplier_payment_method supplier_payment_methods? @relation(fields: [supplier_payment_method_id], references: [id], onDelete: SetNull)
  check                   checks?

  @@index([payment_order_id])
  @@index([supplier_payment_method_id])
}

// ============================================================
// MODELS — Tesorería (Cheques)
// ============================================================

model checks {
  id                       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id               String       @db.Uuid
  type                     check_type
  status                   check_status @default(PORTFOLIO)
  check_number             String
  bank_name                String
  branch                   String?
  account_number           String?
  amount                   Decimal      @db.Decimal(15, 2)
  issue_date               DateTime     @db.Timestamptz
  due_date                 DateTime     @db.Timestamptz
  drawer_name              String
  drawer_tax_id            String?
  payee_name               String?
  customer_id              String?      @db.Uuid
  supplier_id              String?      @db.Uuid
  payment_order_payment_id String?      @unique @db.Uuid
  bank_account_id          String?      @db.Uuid
  bank_movement_id         String?      @unique @db.Uuid
  endorsed_to_name         String?
  endorsed_to_tax_id       String?
  endorsed_at              DateTime?    @db.Timestamptz
  rejected_at              DateTime?    @db.Timestamptz
  rejection_reason         String?
  deposited_at             DateTime?    @db.Timestamptz
  cleared_at               DateTime?    @db.Timestamptz
  notes                    String?
  created_by               String
  created_at               DateTime     @default(now()) @db.Timestamptz
  updated_at               DateTime     @default(now()) @updatedAt @db.Timestamptz

  company               company                 @relation(fields: [company_id], references: [id], onDelete: Cascade)
  customer              customers?              @relation(fields: [customer_id], references: [id])
  supplier              suppliers?              @relation(fields: [supplier_id], references: [id])
  bank_account          bank_accounts?          @relation(fields: [bank_account_id], references: [id])
  bank_movement         bank_movements?         @relation(fields: [bank_movement_id], references: [id])
  payment_order_payment payment_order_payments? @relation(fields: [payment_order_payment_id], references: [id])

  @@index([company_id, type, status])
  @@index([company_id, due_date])
}

// ============================================================
// GASTOS
// ============================================================

model expense_categories {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String   @db.Uuid
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  company  company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  expenses expenses[]

  @@unique([company_id, name])
  @@index([company_id])
}

model expenses {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String         @db.Uuid
  number      Int
  full_number String
  description String
  amount      Decimal        @db.Decimal(15, 2)
  date        DateTime       @db.Date
  due_date    DateTime?      @db.Date
  status      expense_status @default(DRAFT)
  notes       String?
  category_id String         @db.Uuid
  supplier_id String?        @db.Uuid
  created_by  String
  created_at  DateTime       @default(now()) @db.Timestamptz
  updated_at  DateTime       @default(now()) @updatedAt @db.Timestamptz

  company             company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  category            expense_categories   @relation(fields: [category_id], references: [id])
  supplier            suppliers?           @relation(fields: [supplier_id], references: [id])
  expense_attachments expense_attachments[]
  payment_order_items payment_order_items[]

  @@unique([company_id, number])
  @@index([company_id])
  @@index([category_id])
  @@index([supplier_id])
  @@index([status])
}

model expense_attachments {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expense_id String  @db.Uuid
  file_name  String
  file_key   String
  file_size  Int?
  mime_type  String?
  created_at DateTime @default(now()) @db.Timestamptz

  expense expenses @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  @@index([expense_id])
}
