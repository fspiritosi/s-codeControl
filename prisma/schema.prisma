model hse_document_assignments {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id     String         @db.Uuid
  assignee_id     String?        @db.Uuid
  assignee_type   String
  assigned_by     String         @db.Uuid
  assigned_at     DateTime       @default(now()) @db.Timestamptz
  status          hse_doc_status
  accepted_at     DateTime?      @db.Timestamptz
  declined_at     DateTime?      @db.Timestamptz
  declined_reason String?

  document                         hse_documents                      @relation(fields: [document_id], references: [id])
  assignee                         employees?                         @relation(fields: [assignee_id], references: [id])
  hse_document_assignment_versions hse_document_assignment_versions[]
}

model hse_document_assignment_versions {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignment_id       String    @db.Uuid
  document_version_id String    @db.Uuid
  assignee_id         String    @db.Uuid
  status              String    @default("pendiente")
  accepted_at         DateTime? @db.Timestamptz
  declined_at         DateTime? @db.Timestamptz
  declined_reason     String?
  created_at          DateTime  @default(now()) @db.Timestamptz

  assignment       hse_document_assignments @relation(fields: [assignment_id], references: [id])
  document_version hse_document_versions    @relation(fields: [document_version_id], references: [id])
  assignee         employees                @relation(fields: [assignee_id], references: [id])
