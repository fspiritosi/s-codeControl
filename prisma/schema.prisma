model hse_document_versions {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz
  document_id String   @db.Uuid
  created_by  String   @db.Uuid
  version     String
  title       String?
  description String?
  file_name   String
  file_path   String
  file_size   BigInt?
  file_type   String?
  status      String?
  change_log  String?
  expiry_date String?

  document                         hse_documents                      @relation(fields: [document_id], references: [id])
  hse_document_assignment_versions hse_document_assignment_versions[]
}

model hse_document_tag_assignments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz
  document_id String    @db.Uuid
  tag_id      String    @db.Uuid

  document hse_documents @relation(fields: [document_id], references: [id])
  tag      training_tags @relation(fields: [tag_id], references: [id])
}

model hse_document_tags {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz
  name       String
  color      String?
  company_id String?   @db.Uuid
  is_active  Boolean?  @default(true)
  updated_at DateTime? @db.Timestamptz

  company company? @relation(fields: [company_id], references: [id])
}

model hse_document_type_assignmente {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz
  document_id String    @db.Uuid
  docType_id  String    @db.Uuid

  document hse_documents @relation(fields: [document_id], references: [id])
  docType  training_tags @relation(fields: [docType_id], references: [id])
}

// ============================================================
// NEXTAUTH (Auth.js v5) MODELS
// ============================================================

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthUser {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("auth_users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// ENUMS — Almacenes y Compras
// ============================================================

enum product_status {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum product_type {
  PRODUCT
  SERVICE
  RAW_MATERIAL
  CONSUMABLE
}

enum product_purchase_sale_type {
  PURCHASE
  PURCHASE_SALE
}

enum supplier_tax_condition {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  EXENTO
  NO_RESPONSABLE
  CONSUMIDOR_FINAL
}

enum supplier_status {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum supplier_account_type {
  CHECKING
  SAVINGS
}

enum warehouse_type {
  MAIN
  BRANCH
  TRANSIT
  VIRTUAL
}

enum stock_movement_type {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  RETURN
  PRODUCTION
  LOSS
  WITHDRAWAL
}

enum withdrawal_order_status {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  COMPLETED
  CANCELLED
}

enum discount_type {
  PERCENTAGE
  FIXED
}

enum voucher_type {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  NOTA_CREDITO_A
  NOTA_CREDITO_B
  NOTA_CREDITO_C
  NOTA_DEBITO_A
  NOTA_DEBITO_B
  NOTA_DEBITO_C
  RECIBO
}

enum purchase_order_status {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum purchase_order_invoicing_status {
  NOT_INVOICED
  PARTIALLY_INVOICED
  FULLY_INVOICED
}

enum purchase_order_installment_status {
  PENDING
  INVOICED
  PAID
}

enum purchase_invoice_status {
  DRAFT
  CONFIRMED
  PAID
  PARTIAL_PAID
  CANCELLED
}

enum receiving_note_status {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum purchase_invoice_receiving_status {
  NOT_RECEIVED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
